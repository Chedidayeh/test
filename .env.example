# use these environment variables when running the services in docker

NODE_ENV=development
JWT_EXPIRATION=604800
JWT_SECRET=dev-secret-key-change-in-production-please

# ========================================================================
# AI Service Environment Variables
# =======================================================================
AI_PORT=3005
AI_DATABASE_URL=
GOOGLE_PROJECT_ID=
# uploadthing
UPLOADTHING_TOKEN=
SERVICE_ACCOUNT_KEY=


# =======================================================================
# Auth Service Environment Variables
# =======================================================================
AUTH_DATABASE_URL=


# Google OAuth (you'll need to set these from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Service Configuration
AUTH_PORT=3002

# Gateway URL
GATEWAY_URL=

# Child Login Settings
CHILD_LOGIN_CODE_LENGTH=9
CHILD_LOGIN_CODE_ALPHABET="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"


# =======================================================================
# Content Service Environment Variables
# =======================================================================

CONTENT_PORT=3003
CONTENT_DATABASE_URL=
DEEPL_API_KEY=
ENABLE_AUTO_TRANSLATION=true
# =======================================================================
# Progress Service Environment Variables
# =======================================================================
PROGRESS_PORT=3004
PROGRESS_DATABASE_URL=


# =======================================================================
# Gateway Service Environment Variables
# =======================================================================
# Service URLs (should match the service names defined in docker-compose)
AUTH_SERVICE_URL=http://auth-service:3002
CONTENT_SERVICE_URL=http://content-service:3003
PROGRESS_SERVICE_URL=http://progress-service:3004
AI_SERVICE_URL=http://ai-service:3005

# Gateway Configuration
GATEWAY_PORT=3001

