{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",

    "target": "ES2020",
    "module": "CommonJS",

    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}