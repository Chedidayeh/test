# use these environment variables when running the service locally (not in docker)

# Service URLs
AUTH_SERVICE_URL=http://localhost:3002
CONTENT_SERVICE_URL=http://localhost:3003
PROGRESS_SERVICE_URL=http://localhost:3004
AI_SERVICE_URL=http://localhost:3005

# Gateway Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# JWT Configuration (must match Auth Service)
JWT_SECRET=dev-secret-key-change-in-production-please
JWT_EXPIRATION=604800
