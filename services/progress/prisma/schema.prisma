// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Child Profile: Game state for each child
model ChildProfile {
  id             String   @id @default(cuid())
  name           String
  parentId       String // Reference to auth service Parent.id
  childId        String   @unique // Reference to auth service Child.id
  ageGroupId     String // Reference to content service AgeGroup.id
  favoriteThemes String[] // Reference to content service Theme.id

  currentLevel Int @default(1)
  totalStars   Int @default(0)

  progress Progress[]
  badges   ChildBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// Progress represents a child's progress through a specific roadmap , world, story, tracking status, attempts, and rewards earned
model Progress {
  id             String       @id @default(cuid())
  childProfileId String
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  // References to content service (string IDs only - no direct FK)
  roadmapId String // Reference to content service Roadmap.id
  worldId   String // Reference to content service World.id
  storyId   String // Reference to content service Story.id

  status ProgressStatus @default(NOT_STARTED) // "not_started", "in_progress", "completed"


  completedAt DateTime?

  gameSession GameSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Each child tracks progress on each chapter once
  @@unique([childProfileId, storyId])
  @@index([childProfileId])
  @@index([storyId])
}

// GameSession represents a single playthrough of a story, tracking progress and rewards earned during that session
model GameSession {
  id         String   @id @default(cuid())
  progressId String   @unique
  progress   Progress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  // References to content service
  storyId   String // Redundant reference for easier querying of sessions by story
  chapterId String? // Optional reference to chapter for mid-story saves

  startedAt    DateTime  @default(now())
  checkpointAt DateTime? // For mid-session saves
  endedAt      DateTime?

  // Rewards earned in this session
  starsEarned Int @default(0) // 1-3 stars based on performance

  challengeAttempts ChallengeAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([progressId])
  @@index([chapterId])
}

enum ChallengeStatus {
  SOLVED
  SKIPPED
  INCORRECT
  NOT_ATTEMPTED
}

// ChallengeAttempt represents a single attempt at answering a challenge question, tracking the answer given, correctness, hints used, and time spent
model ChallengeAttempt {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // References to content service
  challengeId String // Reference to content service Challenge.id
  answerId    String? // For multiple choice / riddle - reference to content Answer.id

  // Answer data
  textAnswer String? // For short answer challenges - user's free text input
  isCorrect  Boolean? // null for unanswered attempts or subjective questions
  status     ChallengeStatus @default(NOT_ATTEMPTED)

  // Attempt tracking
  attemptNumber Int
  usedHints     Int // Number of hints used (0 = no hints, 1 = 1 hint, etc.)

  // Time tracking (in seconds)
  timeSpentSeconds Int        @default(0)
  starEvent        StarEvent?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([challengeId])
  @@index([answerId])
}

// StarEvent represents the outcome of a challenge attempt that results in star rewards, tracking details of the attempt and rewards earned
model StarEvent {
  id        String           @id @default(cuid())
  attemptId String           @unique
  attempt   ChallengeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  // Reference to content service
  challengeId String // Reference to content service Challenge.id

  // Stars breakdown
  baseStars     Int @default(0)
  noHintBonus   Int @default(0) // +stars if solved without hints
  firstTryBonus Int @default(0) // +stars if solved on first attempt
  totalStars    Int // baseStars + bonuses

  // Challenge attempt info
  attemptNumber Int
  usedHints     Boolean  @default(false)
  wasCorrect    Boolean? // null for unanswered attempts or subjective questions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([attemptId])
  @@index([challengeId])
}

// Child Badge: Track earned badges for each child
model ChildBadge {
  id             String       @id @default(cuid())
  childProfileId String
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  // Reference to content service Badge.id
  badgeId String

  earnedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([childProfileId, badgeId])
  @@index([childProfileId])
}
