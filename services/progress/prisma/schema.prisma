// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Child Profile: Game state for each child
model ChildProfile {
  id                String   @id @default(cuid())
  name              String
  gender            String?
  parentId          String // Reference to auth service Parent.id
  childId           String   @unique // Reference to auth service Child.id
  ageGroupId        String // Reference to content service AgeGroup.id
  ageGroupName      String? // Denormalized for easy access to age group name
  favoriteThemes    String[] // Reference to content service Theme.id
  allocatedRoadmaps String[] // List of Roadmap IDs allocated to this child
  currentLevel      Int      @default(1)
  totalStars        Int      @default(0)

  activateWeeklyReports Boolean @default(false)
  // push notification preferences
  activateNotifications Boolean @default(false)
  sessionsPerWeek       Int     @default(3)

  storytelling  StorytellingProfile?
  dailyActivity ChildDailyActivity?

  progress Progress[]
  badges   ChildBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
}

// child daily activity for notifications push
model ChildDailyActivity {
  id             String       @id @default(cuid())
  childProfileId String       @unique
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  lastActiveAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StorytellingProfile {
  id             String       @id @default(cuid())
  childProfileId String       @unique
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  childName          String
  childLanguage      String
  favoriteThemes     String[] // hand picked by the parent during onboarding
  learningObjectives String[] // optional learning objectives for the AI to focus on

  onboardingCompleted Boolean @default(false)
  isActive            Boolean @default(true)

  stories StorytellingStory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StorytellingStory {
  id                    String              @id @default(cuid())
  storytellingProfileId String
  storytellingProfile   StorytellingProfile @relation(fields: [storytellingProfileId], references: [id], onDelete: Cascade)

  // Reference to content service StorytellingStory.id
  storyId          String
  title            String
  generatedStoryId String? //  reference to the original generated story ID from AI Service

  status   ProgressStatus @default(NOT_STARTED) // "not_started", "in_progress", "completed"
  progress Progress?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storytellingProfileId])
  @@index([storyId])
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// Progress represents a child's progress through a specific roadmap , world, story, tracking status, attempts, and rewards earned
model Progress {
  id             String       @id @default(cuid())
  childProfileId String
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  storytellingStoryId String?            @unique // Optional reference to StorytellingStory for AI-generated stories
  storytellingStory   StorytellingStory? @relation(fields: [storytellingStoryId], references: [id], onDelete: Cascade)

  // References to content service (string IDs only - no direct FK)
  roadmapId        String? // Reference to content service Roadmap.id
  worldId          String? // Reference to content service World.id
  storyId          String? // Reference to content service Story.id
  generatedStoryId String? //  reference to the original generated story ID from AI Service

  status ProgressStatus @default(NOT_STARTED) // "not_started", "in_progress", "completed"

  // Total time spent on this story across all sessions/attempts (in seconds)
  totalTimeSpent Int @default(0)

  completedAt DateTime?

  gameSession GameSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Each child tracks progress on each chapter once
  @@unique([childProfileId, storyId])
  @@index([childProfileId])
  @@index([storyId])
}

// GameSession represents a single playthrough of a story, tracking progress and rewards earned during that session
model GameSession {
  id         String   @id @default(cuid())
  progressId String   @unique
  progress   Progress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  // References to content service
  storyId   String // Redundant reference for easier querying of sessions by story
  chapterId String? // Optional reference to chapter for mid-story saves

  startedAt    DateTime  @default(now())
  checkpointAt DateTime? // Legacy field: timestamp of latest checkpoint (will be deprecated in favor of SessionCheckpoint records)
  endedAt      DateTime?

  // Time tracking fields (calculated from checkpoints)
  elapsedTimeSeconds Int @default(0) // Time spent in current session (in seconds, calculated from chapters checkpoints)
  // totalTimeSpent Int @default(0) // Total active time in seconds (sum of all pause-to-resume durations)
  sessionCount       Int @default(1) // Number of separate sessions (pause/resume cycles)
  totalIdleTime      Int @default(0) // Total time child was away between sessions (sum of idle periods)

  // Rewards earned in this session
  starsEarned Int @default(0)

  // Relations
  challengeAttempts ChallengeAttempt[]
  checkpoints       SessionCheckpoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([progressId])
  @@index([chapterId])
  @@index([storyId])
}

// SessionCheckpoint records each pause/resume event within a GameSession
// Allows tracking of when child paused, resumed, and calculating idle time between sessions
model SessionCheckpoint {
  id String @id @default(cuid())

  gameSessionId String
  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  firstChapterId String
  lastChapterId  String?

  // Timestamp when child startedAt
  startedAt DateTime @default(now())

  // Timestamp when child paused checkpoint
  pausedAt DateTime?

  // Duration from started to paused in seconds
  sessionDurationSeconds Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([gameSessionId])
  @@index([firstChapterId])
  @@index([lastChapterId])
  @@index([pausedAt])
  @@index([startedAt])
}

enum ChallengeStatus {
  SOLVED
  SKIPPED
  INCORRECT
  NOT_ATTEMPTED
}

// ChallengeAttempt represents a single attempt at answering a challenge question, tracking the answer given, correctness, hints used, and time spent
model ChallengeAttempt {
  id        String      @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // References to content service
  challengeId String // Reference to content service Challenge.id

  // Final answer data (what they ultimately submitted)
  answerId   String? // Final answer selected
  textAnswer String? // For short answer challenges - user's free text input
  isCorrect  Boolean? // null for unanswered attempts or subjective questions
  status     ChallengeStatus @default(NOT_ATTEMPTED)

  // Attempt tracking
  attemptNumber Int
  usedHints     Int // Number of hints used (0 = no hints, 1 = 1 hint, etc.)

  // Time tracking (in seconds)
  timeSpentSeconds Int @default(0)

  // Detailed action history during this attempt
  actions AttemptAction[]

  starEvent StarEvent?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([challengeId])
}

// Store every action a child takes during a challenge attempt
// Provides detailed audit trail of their decision-making process
model AttemptAction {
  id        String           @id @default(cuid())
  attemptId String
  attempt   ChallengeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  // What was selected/used in this action
  selectedAnswerId      String? // If action is ANSWER_SUBMITTED
  selectedAnswerText    String? // Capture the full text of the answer they selected
  answerText            String? // For open-ended questions, capture the text they entered
  isCorrect             Boolean? // Whether this action resulted in a correct answer (null for non-answer actions)
  // Context about this action
  attemptNumberAtAction Int // Which attempt number they were on

  createdAt DateTime @default(now())

  @@index([attemptId])
  @@index([selectedAnswerId])
  @@index([createdAt])
}

// StarEvent represents the outcome of a challenge attempt that results in star rewards, tracking details of the attempt and rewards earned
model StarEvent {
  id        String           @id @default(cuid())
  attemptId String           @unique
  attempt   ChallengeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  // Reference to content service
  challengeId String // Reference to content service Challenge.id

  // Stars breakdown
  baseStars     Int @default(0)
  noHintBonus   Int @default(0) // +stars if solved without hints
  firstTryBonus Int @default(0) // +stars if solved on first attempt
  totalStars    Int // baseStars + bonuses

  // Challenge attempt info
  attemptNumber Int
  usedHints     Boolean  @default(false)
  wasCorrect    Boolean? // null for unanswered attempts or subjective questions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([attemptId])
  @@index([challengeId])
}

// Child Badge: Track earned badges for each child
model ChildBadge {
  id             String       @id @default(cuid())
  childProfileId String
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  // Reference to content service Badge.id
  badgeId String

  earnedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([childProfileId, badgeId])
  @@index([childProfileId])
}
