// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// TTSAudio: stores generated TTS recordings and metadata
model TTSAudio {
  id          String   @id @default(cuid())

  // Optional foreign identifiers (stored as plain IDs so they can reference other services)
  storyId     String?  // ID of the story this audio is for
  chapterId   String?  // ID of the chapter this audio is for
  challengeId String?  // ID of the challenge this audio is for (if applicable)

  // TTS metadata
  languageCode String?
  voice        String?
  prompt       String?

  // Location of the stored audio file (URL or path)
  audioUrl     String
  mimeType     String  @default("audio/wav")

  // Optional technical metadata
  durationMs   Int?
  sizeBytes    Int?

  // When the audio was generated and recorded
  generatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([storyId])
  @@index([chapterId])
}

// LLMValidationResult stores AI validation responses for challenge attempts
// Tracks the LLM's confidence, reasoning, and child-friendly message
model LLMValidationResult {
  id String @id @default(cuid())

  // References to other services (stored as plain IDs)
  storyId             String  // ID of the story this validation is for
  chapterId           String  // ID of the chapter this validation is for
  challengeAttemptId  String  // ID of the challenge attempt from progress service
  attemptActionId     String? // Optional reference to attempt action ID from progress service

  childAnswer        String

  // LLM validation data
  correct    Boolean // Whether the child's answer was correct
  confidence Float // Confidence score (0.0 - 1.0)
  reason     String // Explanation of validation (max 15 words)
  message    String // Child-friendly message (max 20 words)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storyId])
  @@index([chapterId])
  @@index([challengeAttemptId])
  @@index([attemptActionId])
}

// AIProgressInsight stores the complete analytics response from generateAnalytics controller
// Contains reading level, engagement score, insights, and metrics for future reference
// Allows multiple insights per child per week for comparison and tracking evolution
model AIProgressInsight {
  id String @id @default(cuid())

  // Child reference (foreign key to Progress Service)
  childId String

  // Time period this insight covers (weekly analytics)
  periodStart DateTime
  periodEnd   DateTime

  // Reading assessment
  readingLevel String // BEGINNER | EASY | MEDIUM | HARD | ADVANCED
  engagementScore Int // 0-100 percentage

  // All insights data stored as JSON
  // Structure: { strengths: string[], weaknesses: string[], recommendations: Recommendation[], tips: string[] }
  insights Json

  // All metrics data stored as JSON
  // Structure: { totalStoriesCompleted, totalChallengesAttempted, totalChallengesSolved, 
  //             successRate, averageAttemptsPerChallenge, hintDependencyRate, starAchievementRate }
  metrics Json

  // Audit trail
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for efficient queries
  @@index([childId])
  @@index([periodStart])
  @@index([periodEnd])
}
