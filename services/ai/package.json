    "@langchain/google-vertexai": "^2.1.26",
    "@pinecone-database/pinecone": "^7.1.0",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "inngest": "^3.52.6",
    "langchain": "^1.2.35",
    "uploadthing": "^7.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
