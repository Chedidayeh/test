# use these environment variables when running the service locally (not in docker)
# DATABASE_URL="postgresql://auth_user:auth_pass@localhost:5435/auth_db?schema=public"
DATABASE_URL=

# JWT Configuration (must match gateway Service)
JWT_SECRET=dev-secret-key-change-in-production-please
JWT_EXPIRATION=604800


# Google OAuth (you'll need to set these from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Service Configuration
PORT=3002
NODE_ENV="development"

# Gateway URL
GATEWAY_URL="http://localhost:3001"

# Child Login Settings
CHILD_LOGIN_CODE_LENGTH=9
CHILD_LOGIN_CODE_ALPHABET="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
