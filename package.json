{
  "name": "story-game",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "install:all": "concurrently \"npm run install:gateway\" \"npm run install:content\" \"npm run install:progress\" \"npm run install:auth\" \"npm run install:ai\"",
    "install:auth": " npm --prefix services/auth install",
    "install:content": " npm --prefix services/content install",
    "install:progress": " npm --prefix services/progress install",
    "install:gateway": " npm --prefix services/gateway install",
    "install:ai": " npm --prefix services/ai install",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:content\" \"npm run dev:progress\" \"npm run dev:auth\" \"npm run dev:ai\"",
    "dev:gateway": "npm --prefix services/gateway run dev",
    "dev:content": "npm --prefix services/content run dev",
    "dev:progress": "npm --prefix services/progress run dev",
    "dev:auth": "npm --prefix services/auth run dev",
    "dev:ai": "npm --prefix services/ai run dev",
    "build:all": "concurrently \"npm run build:gateway\" \"npm run build:content\" \"npm run build:progress\" \"npm run build:auth\" \"npm run build:ai\"",
    "build:shared": "npm --prefix packages/shared run build",
    "build:auth": "npm --prefix services/auth run build",
    "build:ai": "npm --prefix services/ai run build",
    "build:content": "npm --prefix services/content run build",
    "build:progress": "npm --prefix services/progress run build",
    "build:gateway": "npm --prefix services/gateway run build",
    "build": "npm run build:shared && npm --prefix apps/web run build",
    "prisma:generate": "npm run prisma:generate:ai && npm run prisma:generate:auth && npm run prisma:generate:content && npm run prisma:generate:progress",
    "prisma:generate:ai": "npm --prefix services/ai run prisma:generate",
    "prisma:generate:auth": "npm --prefix services/auth run prisma:generate",
    "prisma:generate:content": "npm --prefix services/content run prisma:generate",
    "prisma:generate:progress": "npm --prefix services/progress run prisma:generate",
    "start:all": "concurrently \"npm run start:gateway\" \"npm run start:content\" \"npm run start:progress\" \"npm run start:auth\" \"npm run start:ai\"",
    "start:gateway": "npm --prefix services/gateway run start",
    "start:content": "npm --prefix services/content run start",
    "start:progress": "npm --prefix services/progress run start",
    "start:auth": "npm --prefix services/auth run start",
    "start:ai": "npm --prefix services/ai run start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}